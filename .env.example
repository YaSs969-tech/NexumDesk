# ============================================
# BACKEND CONFIGURATION
# ============================================

# Server
PORT=3001
NODE_ENV=development

# Database
SQLITE_FILE=./data/nexumdesk.db
# Uncomment when migrating to PostgreSQL:
# DATABASE_URL=postgresql://user:password@localhost:5432/nexumdesk

# Authentication
JWT_SECRET=your_very_secret_key_min_32_characters_long
JWT_EXPIRY=1h

# Logging
LOG_LEVEL=info

# CORS
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ============================================
# FRONTEND CONFIGURATION (Vite)
# ============================================

# API (use VITE_ prefix for Vite)
VITE_API_URL=http://localhost:3001/api/v1
VITE_ENV=development

# ============================================
# PRODUCTION VALUES (example)
# ============================================
# Note: Replace these when deploying to production

# Production backend:
# PORT=3001
# NODE_ENV=production
# JWT_SECRET=<generate-random-secret>
# DATABASE_URL=postgresql://prod_user:prod_pass@prod-db.aws.amazonaws.com:5432/nexumdesk
# ALLOWED_ORIGINS=https://example.com

# Production frontend:
# VITE_API_URL=https://api.example.com/api/v1
# VITE_ENV=production
